{
  "branches": ["master"],
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      {
        "changelogFile": "CHANGELOG.md"
      }
    ],
    [
      "@semantic-release/github",
      {
        "assets": [
          { "path": "dist/domains-exporter-linux-amd64",  "label": "Binary (Linux amd64)" },
          { "path": "dist/domains-exporter-linux-arm64",  "label": "Binary (Linux arm64)" },
          { "path": "dist/domains-exporter-darwin-amd64", "label": "Binary (macOS amd64)" },
          { "path": "dist/domains-exporter-darwin-arm64", "label": "Binary (macOS arm64)" }
        ]
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ]
  ]
}
